    <tags>XrmToolBox Dataverse PowerPlatform CopilotStudio MicrosoftCopilot Security ALM Deployment Bot Plugin Dynamics365</tags>
    <dependencies>
      <group targetFramework="any">
        <dependency id="XrmToolBox" version="[1.2023.10.67, )" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="bin\Release\CopilotStudioHealthMonitor.dll" target="lib\net452\Plugins" />
  </files>
</package>
